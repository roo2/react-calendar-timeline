# Local development defaults (SQLite - no DB server required)
DATABASE_URL=sqlite+pysqlite:///./production.db
ENV=dev

# Notes:
# - To use PostgreSQL instead, set:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/dbname
# - The application reads .env automatically (see app/config.py).
# - SQLite database file 'production.db' will be created in project root.



# Local development defaults (SQLite - no DB server required)
DATABASE_URL=sqlite+pysqlite:///./production.db
ENV=dev

# Notes:
# - To use PostgreSQL instead, set:
#   DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/dbname
# - The application reads .env automatically (see app/config.py).
# - SQLite database file 'production.db' will be created in project root.

# Printing artwork PDFs (S3). When S3_BUCKET is unset, upload/download API returns 503.
# Local dev (see infrastructure/README.md): default bucket name crownpack-production-local (default AWS profile).
# S3_BUCKET=crownpack-production-local
# Production / Heroku: crownpack-production (deploy with prod profile).
# S3_BUCKET=crownpack-production
# S3_REGION=ap-southeast-2
# S3_PRINTING_ARTWORK_PREFIX=printing/
# S3_PRINTING_ARTWORK_URL_TTL_SECONDS=900
# PRINTING_ARTWORK_MAX_BYTES=26214400

# MYOB Business API (OAuth). Key/secret from the MYOB developer portal.
# MYOB_APP_KEY=
# MYOB_APP_SECRET=
# Must match the redirect URI registered with MYOB exactly (same host/path as the browser uses).
# Local Vite dev (proxies /api to the backend):
# MYOB_REDIRECT_URI=http://localhost:5173/api/myob
# Production (example):
# MYOB_REDIRECT_URI=https://your-app.herokuapp.com/api/myob
# OAuth scopes are defined in app/config.py (`MYOB_SCOPES`, includes inventory for order line UOM), not in this file.
#
# Company file GUID for API URLs (…/accountright/{id}/…). Overrides DB if set (same as MYOB_APP_KEY-style config).
# MYOB_COMPANY_FILE_ID=
#
# Token refresh (recommended: every 10–15 minutes; access tokens are short-lived):
# - Heroku: add Heroku Scheduler add-on, then create a job:
#     Command:  python -m app.integrations.myob.cli
#     Frequency: Every 10 minutes (closest to 15m on Heroku Scheduler; or hourly if acceptable)
#   Ensure DATABASE_URL and MYOB_* config vars are set on the app.
# - Local: cron every 15 minutes, from the repo root (adjust Python path):
#     */15 * * * * cd /path/to/Production_software && .venv/bin/python -m app.integrations.myob.cli >> /tmp/myob-refresh.log 2>&1

# Xero (OAuth 2.0). Key/secret from the Xero developer portal.
# XERO_CLIENT_ID=
# XERO_CLIENT_SECRET=
# Must match the redirect URI registered with Xero exactly (same host/path as the browser uses).
# Local Vite dev (proxies /api to the backend):
# XERO_REDIRECT_URI=http://localhost:5173/api/xero/oauth/callback
# Production (example):
# XERO_REDIRECT_URI=https://your-app.herokuapp.com/api/xero/oauth/callback
# OAuth scopes are defined in app/config.py (`XERO_SCOPES`, includes offline_access for refresh tokens), not in this file.
#
# Token refresh (recommended: every 10–30 minutes; access tokens are short-lived):
# - Heroku: add Heroku Scheduler add-on, then create a job:
#     Command:  python -m app.integrations.xero.cli
#     Frequency: Every 10 minutes (or hourly if acceptable)
#   Ensure DATABASE_URL and XERO_* config vars are set on the app.
# - Local: cron every 15 minutes, from the repo root:
#     */15 * * * * cd /path/to/Production_software && .venv/bin/python -m app.integrations.xero.cli >> /tmp/xero-refresh.log 2>&1


